{
  "info": {
    "name": "LMS Backend - Auth API",
    "description": "Postman collection for testing LMS Authentication APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('verification_token', jsonData.data.verificationCode); // 6-digit code",
                  "    pm.environment.set('user_id', jsonData.data.user.id);",
                  "    pm.environment.set('user_email', jsonData.data.user.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"name\\\": \\\"Trịnh Ngọc Thái\\\",\\n  \\\"email\\\": \\\"thai@example.com\\\",\\n  \\\"password\\\": \\\"password123\\\",\\n  \\\"role\\\": \\\"student\\\"\\n}",
              "raw": "{\\n  \\\"name\\\": \\\"Trịnh Ngọc Thái\\\",\\n  \\\"username\\\": \\\"thaingocthai\\\",\\n  \\\"email\\\": \\\"thai@example.com\\\",\\n  \\\"phone\\\": \\\"+84901234567\\\",\\n  \\\"password\\\": \\\"password123\\\",\\n  \\\"role\\\": \\\"student\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Verify Email by Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"token\\\": \\\"your_verification_token_here\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-email-code",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-email-code"
              ]
            }
          }
        },
        {
          "name": "Resend Verification Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"email\\\": \\\"thai@example.com\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/resend-verification-email",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "resend-verification-email"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('auth_token', jsonData.data.token);",
                  "    pm.environment.set('user_id', jsonData.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"username\\\": \\\"thaingocthai\\\",\\n  \\\"password\\\": \\\"password123\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"email\\\": \\\"thai@example.com\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/forgot-password",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "forgot-password"
              ]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"token\\\": \\\"your_reset_password_token_here\\\",\\n  \\\"password\\\": \\\"newpassword123\\\",\\n  \\\"confirmPassword\\\": \\\"newpassword123\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/reset-password",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "reset-password"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "Enroll in course",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var d = pm.response.json();",
                  "  if (d.data && d.data.enrollment) pm.environment.set('enrollment_id', d.data.enrollment.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/student/courses/{{course_id}}/enroll",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "courses", "{{course_id}}", "enroll"]
            }
          }
        },
        {
          "name": "Get my enrollments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/student/enrollments",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "enrollments"]
            }
          }
        },
        {
          "name": "Get enrollment by course",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/student/enrollments/course/{{course_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "enrollments", "course", "{{course_id}}"]
            }
          }
        },
        {
          "name": "Update progress",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"progressPercent\": 75\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/student/progress/{{course_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "progress", "{{course_id}}"]
            }
          }
        },
        {
          "name": "Unenroll",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/student/courses/{{course_id}}/enroll",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "courses", "{{course_id}}", "enroll"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_email",
      "value": "thai@example.com",
      "type": "string"
    },
    {
      "key": "course_id",
      "value": "1",
      "type": "string"
    }
  ]
}
