{
  "info": {
    "name": "Placement Test API",
    "description": "API collection for adaptive placement testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Start Placement Test",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/student/placement/start",
          "host": ["{{baseUrl}}"],
          "path": ["student", "placement", "start"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetCourseId\": 1,\n  \"selfAssessedLevel\": \"B1\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Session created', function () {",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data.sessionId).to.exist;",
              "});",
              "",
              "// Save sessionId for next requests",
              "pm.collectionVariables.set('placementSessionId', jsonData.data.sessionId);",
              "console.log('Session ID:', jsonData.data.sessionId);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Quick Check (Optional)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/student/placement/quick-check",
          "host": ["{{baseUrl}}"],
          "path": ["student", "placement", "quick-check"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetCourseId\": 1\n}"
        }
      }
    },
    {
      "name": "3. Get Next Question",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/student/placement/{{placementSessionId}}/question",
          "host": ["{{baseUrl}}"],
          "path": ["student", "placement", "{{placementSessionId}}", "question"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get question success', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "if (jsonData.data.completed) {",
              "    console.log('Test completed!');",
              "} else {",
              "    pm.collectionVariables.set('currentQuestionId', jsonData.data.questionId);",
              "    console.log('Question:', jsonData.data.content);",
              "    console.log('Options:', jsonData.data.options);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. Submit Answer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/student/placement/{{placementSessionId}}/answer",
          "host": ["{{baseUrl}}"],
          "path": ["student", "placement", "{{placementSessionId}}", "answer"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"questionId\": {{currentQuestionId}},\n  \"answer\": \"A\",\n  \"timeSpentSeconds\": 15\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "console.log('Answer correct:', jsonData.data.isCorrect);",
              "console.log('Current level:', jsonData.data.currentLevel);",
              "console.log('Streak correct:', jsonData.data.streakCorrect);",
              "console.log('Streak wrong:', jsonData.data.streakWrong);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Complete Test",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/student/placement/{{placementSessionId}}/complete",
          "host": ["{{baseUrl}}"],
          "path": ["student", "placement", "{{placementSessionId}}", "complete"]
        }
      }
    },
    {
      "name": "6. Get Result",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/student/placement/{{placementSessionId}}/result",
          "host": ["{{baseUrl}}"],
          "path": ["student", "placement", "{{placementSessionId}}", "result"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "console.log('Final Level:', jsonData.data.finalLevel);",
              "console.log('Confidence:', jsonData.data.confidenceScore);",
              "console.log('Total questions:', jsonData.data.totalQuestions);",
              "console.log('Correct answers:', jsonData.data.correctAnswers);",
              "console.log('Skill breakdown:', jsonData.data.skillBreakdown);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://cicd-test1.onrender.com/api"
    },
    {
      "key": "studentToken",
      "value": ""
    },
    {
      "key": "placementSessionId",
      "value": ""
    },
    {
      "key": "currentQuestionId",
      "value": ""
    }
  ]
}
