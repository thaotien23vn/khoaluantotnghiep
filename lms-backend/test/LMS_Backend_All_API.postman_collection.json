          "name": "POST /api/auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const d = pm.response.json();",
                  "  if (d?.data?.verificationCode) pm.environment.set('verification_token', d.data.verificationCode);",
                  "  if (d?.data?.user?.id) pm.environment.set('user_id', String(d.data.user.id));",
                  "}"
                ]
              }
